# Caesar AI Incident Atlas — environment variable reference
# Copy to .env and fill in real values. NEVER commit .env.
# .env is gitignored. Only .env.example is tracked.

# Supabase hosted database
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Hosted sync mode: dry_run (default) | push
# Must be set to push AND ATLAS_CONFIRM_HOSTED_SYNC=YES to perform real sync
ATLAS_HOSTED_SYNC_MODE=dry_run

# Explicit confirmation required to perform real hosted push
# Set to YES only after reviewing bootstrap payloads and confirming remote project is ready
ATLAS_CONFIRM_HOSTED_SYNC=

# Cloudflare Worker — watch run trigger (default: false, do not enable without explicit approval)
ENABLE_WATCH_RUNS=false

# Optional: inline ops status JSON for Cloudflare Worker env
OPS_STATUS_JSON=

# Optional: inline latest run JSON for Cloudflare Worker env
LATEST_RUN_JSON=
