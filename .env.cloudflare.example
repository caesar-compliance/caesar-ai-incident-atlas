# Caesar AI Incident Atlas — Cloudflare (placeholders only)
# Copy to .env.cloudflare.local and fill in locally. Never commit .env.cloudflare.local.
# See also infra/cloudflare-worker/wrangler.example.toml for Worker scaffold.

CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_WORKER_NAME=incident-atlas-monitor-dev
CLOUDFLARE_ENABLE_WORKER_DEPLOY=false
CLOUDFLARE_ENABLE_CRON_TRIGGER=false
