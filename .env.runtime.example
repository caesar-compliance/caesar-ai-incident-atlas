# Caesar AI Incident Atlas — runtime environment (placeholders only)
# Copy to .env.runtime.local and fill in locally. Never commit .env.runtime.local.
# Legacy hosted sync may still use .env — keep both in sync locally when activating.

SUPABASE_PROJECT_NAME=caesar-incident-atlas-dev
SUPABASE_URL=
SUPABASE_PROJECT_REF=
SUPABASE_DB_URL=
SUPABASE_SCHEMA=public

# Preferred: Supabase publishable/secret API keys (Dashboard → API → API Keys)
SUPABASE_API_KEY_MODE=new
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=

# Optional deprecated fallback (legacy JWT anon/service_role keys)
# SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

RUNTIME_ENV=local
ENABLE_LIVE_INGESTION=false
ENABLE_SCHEDULED_MONITORING=false
ENABLE_NETWORK_EXECUTION=false
APPLY_SUPABASE_SCHEMA=false
