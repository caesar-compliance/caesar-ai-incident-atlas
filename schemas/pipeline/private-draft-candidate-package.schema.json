{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://caesar.no/schemas/pipeline/private-draft-candidate-package.schema.json",
  "title": "Caesar AI Legal & Governance Case Atlas — Private Draft Candidate Package Schema",
  "type": "object",
  "required": [
    "package_id",
    "created_at",
    "source_run_id",
    "intake_id",
    "decision_id",
    "approval_id",
    "candidate_hash",
    "source_id",
    "source_name",
    "source_url",
    "draft_status",
    "suggested_title",
    "suggested_record_type",
    "legal_governance_relevance",
    "suggested_failure_modes",
    "suggested_control_themes",
    "suggested_evidence_questions",
    "suggested_vendor_questions",
    "governance_chain",
    "public_readiness",
    "missing_review_items",
    "human_review_required",
    "public_publish_ready",
    "promotion_packet_created",
    "public_preview_created",
    "public_site_mutated",
    "remote_write_attempted",
    "raw_text_stored",
    "html_stored",
    "safety_flags"
  ],
  "properties": {
    "package_id": {
      "type": "string",
      "pattern": "^DRAFT-CAND-PKG-[A-Z0-9-]+-[0-9]{3}$",
      "description": "Unique, deterministic private draft candidate package ID."
    },
    "created_at": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(\\.[0-9]+)?Z$",
      "description": "ISO 8601 UTC timestamp of creation."
    },
    "source_run_id": {
      "type": "string",
      "description": "The green source run ID linked to this ingestion cycle."
    },
    "intake_id": {
      "type": "string",
      "pattern": "^INTAKE-[A-Z0-9-]+-[0-9]{3}$",
      "description": "Linked intake record ID."
    },
    "decision_id": {
      "type": "string",
      "pattern": "^DECISION-[A-Z0-9-]+-[0-9]{3}$",
      "description": "Linked decision record ID."
    },
    "approval_id": {
      "type": "string",
      "pattern": "^APPROVAL-[A-Z0-9-]+-[0-9]{3}$",
      "description": "Linked approval marker ID."
    },
    "candidate_hash": {
      "type": "string",
      "description": "Hash of the candidate intake signal."
    },
    "source_id": {
      "type": "string",
      "description": "Source unique identifier."
    },
    "source_name": {
      "type": "string",
      "description": "Source human-readable name."
    },
    "source_url": {
      "type": "string",
      "description": "Primary URL of the source."
    },
    "draft_status": {
      "type": "string",
      "const": "private_draft_candidate",
      "description": "Hard constraint: must be private_draft_candidate."
    },
    "suggested_title": {
      "type": "string",
      "description": "Suggested title for the case draft."
    },
    "suggested_record_type": {
      "type": "string",
      "description": "Suggested record type."
    },
    "legal_governance_relevance": {
      "type": "string",
      "description": "Level of legal or governance relevance."
    },
    "suggested_failure_modes": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Suggested failure mode taxonomies."
    },
    "suggested_control_themes": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Suggested compliance control theme taxonomies."
    },
    "suggested_evidence_questions": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Suggested evidence audit questions."
    },
    "suggested_vendor_questions": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Suggested vendor risk questions."
    },
    "governance_chain": {
      "type": "object",
      "required": [
        "candidate_signal",
        "legal_or_governance_risk",
        "likely_failure_mode",
        "missing_controls",
        "required_evidence",
        "vendor_questions",
        "training_lesson",
        "client_checklist_items"
      ],
      "properties": {
        "candidate_signal": { "type": "string" },
        "legal_or_governance_risk": { "type": "string" },
        "likely_failure_mode": { "type": "string" },
        "missing_controls": { "type": "string" },
        "required_evidence": { "type": "string" },
        "vendor_questions": { "type": "string" },
        "training_lesson": { "type": "string" },
        "client_checklist_items": { "type": "string" }
      },
      "additionalProperties": false
    },
    "public_readiness": {
      "type": "object",
      "required": [
        "status",
        "blockers",
        "allowed_next_step"
      ],
      "properties": {
        "status": { "type": "string", "const": "not_ready" },
        "blockers": {
          "type": "array",
          "items": { "type": "string" }
        },
        "allowed_next_step": { "type": "string", "const": "private_package_review_only" }
      },
      "additionalProperties": false
    },
    "missing_review_items": {
      "type": "array",
      "items": { "type": "string" },
      "description": "List of missing items or tasks before publication is allowed."
    },
    "human_review_required": {
      "type": "boolean",
      "const": true,
      "description": "Must be true."
    },
    "public_publish_ready": {
      "type": "boolean",
      "const": false,
      "description": "Must be false."
    },
    "promotion_packet_created": {
      "type": "boolean",
      "const": false,
      "description": "Must be false."
    },
    "public_preview_created": {
      "type": "boolean",
      "const": false,
      "description": "Must be false."
    },
    "public_site_mutated": {
      "type": "boolean",
      "const": false,
      "description": "Must be false."
    },
    "remote_write_attempted": {
      "type": "boolean",
      "const": false,
      "description": "Must be false."
    },
    "raw_text_stored": {
      "type": "boolean",
      "const": false,
      "description": "Must be false."
    },
    "html_stored": {
      "type": "boolean",
      "const": false,
      "description": "Must be false."
    },
    "safety_flags": {
      "type": "object",
      "required": [
        "no_raw_html",
        "no_long_third_party_text",
        "no_secrets_exposed",
        "no_unauthorized_remote_writes",
        "no_public_site_leak"
      ],
      "properties": {
        "no_raw_html": { "type": "boolean", "const": true },
        "no_long_third_party_text": { "type": "boolean", "const": true },
        "no_secrets_exposed": { "type": "boolean", "const": true },
        "no_unauthorized_remote_writes": { "type": "boolean", "const": true },
        "no_public_site_leak": { "type": "boolean", "const": true }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
