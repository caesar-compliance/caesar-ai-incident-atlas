{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://caesar.no/schemas/pipeline/candidate.schema.json",
  "title": "Caesar AI Legal & Governance Case Atlas — Ingestion Candidate Schema",
  "type": "object",
  "required": [
    "candidate_id",
    "detected_at",
    "source_id",
    "source_url",
    "title",
    "date_published",
    "detected_keywords",
    "preliminary_case_type",
    "jurisdiction",
    "source_tier",
    "confidence_score",
    "dedupe_key",
    "status",
    "risk_flags"
  ],
  "properties": {
    "candidate_id": {
      "type": "string",
      "pattern": "^CAND-[0-9]{4}$",
      "description": "Unique candidate identifier (CAND-NNNN format)."
    },
    "detected_at": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$",
      "description": "ISO 8601 UTC timestamp of discovery."
    },
    "source_id": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$",
      "description": "Reference source ID matching sources.yml."
    },
    "source_url": {
      "type": "string",
      "format": "uri",
      "description": "Direct URL to the source announcement, filing, or article."
    },
    "title": {
      "type": "string",
      "minLength": 5,
      "description": "Original raw title of the discovery item."
    },
    "date_published": {
      "type": "string",
      "pattern": "^[0-9]{1,2} [A-Z][a-z]+ [0-9]{4}$",
      "description": "Date format matching the main dataset (e.g., 21 May 2026)."
    },
    "detected_keywords": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "List of keywords triggered during detection (e.g., algorithmic bias, hiring software)."
    },
    "preliminary_case_type": {
      "type": "string",
      "enum": [
        "enforcement",
        "lawsuit",
        "regulator_guidance",
        "court_decision",
        "settlement",
        "public_sector_incident",
        "vendor_governance_failure",
        "serious_incident_report",
        "commercial_ai_failure",
        "official_investigation"
      ],
      "description": "Conceptual case type classification."
    },
    "jurisdiction": {
      "type": "string",
      "description": "Extracted regional jurisdiction."
    },
    "source_tier": {
      "type": "string",
      "enum": ["green", "yellow", "red"],
      "description": "Source tier determining extraction rules and publishing gates."
    },
    "confidence_score": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0,
      "description": "Automated confidence of algorithmic classification relevance."
    },
    "dedupe_key": {
      "type": "string",
      "description": "Hash of URL/title used to block duplicate candidate records."
    },
    "status": {
      "type": "string",
      "enum": ["unprocessed", "reviewed", "promoted_to_draft", "dismissed_duplicate", "dismissed_low_relevance"],
      "description": "Current processing state in the ingestion queue."
    },
    "risk_flags": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["high_defamation_risk", "unclear_license", "paywall_restricted", "named_individuals", "no_risk_detected"]
      },
      "description": "Ingestion safety and copyright risk alerts."
    },
    "notes": {
      "type": "string",
      "description": "Developer or review comments."
    }
  },
  "additionalProperties": false
}
