{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://caesar.no/schemas/pipeline/private-publication-blocker-resolution.schema.json",
  "title": "Private Publication Blocker Resolution Dossier Schema",
  "description": "Schema for private publication blocker resolution dossier. This is NOT publication approval. All public/remote flags must be strictly false.",
  "type": "object",
  "required": [
    "resolution_id",
    "created_at",
    "source_run_id",
    "selected_intake_id",
    "selected_decision_id",
    "active_approval_id",
    "package_id",
    "dry_run_id",
    "signoff_id",
    "promotion_packet_candidate_id",
    "status",
    "private_blocker_resolution_dossier_only",
    "not_publication_approval",
    "not_real_promotion_packet",
    "not_public_preview",
    "not_public_record_creation",
    "public_publish_allowed",
    "real_promotion_packet_allowed",
    "public_preview_allowed",
    "public_record_creation_allowed",
    "remote_write_allowed",
    "raw_text_storage_allowed",
    "html_storage_allowed",
    "blocker_ledger",
    "safety_flags"
  ],
  "properties": {
    "resolution_id": {
      "type": "string",
      "pattern": "^PUB-BLOCKER-RES-[A-Z0-9-]+-[0-9]{3}$",
      "description": "Deterministic resolution dossier ID."
    },
    "created_at": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(\\.[0-9]+)?Z$",
      "description": "ISO 8601 UTC timestamp of creation."
    },
    "source_run_id": {
      "type": "string",
      "description": "Linked regulatory source green run ID."
    },
    "selected_intake_id": {
      "type": "string"
    },
    "selected_decision_id": {
      "type": "string"
    },
    "active_approval_id": {
      "type": "string"
    },
    "package_id": {
      "type": "string"
    },
    "dry_run_id": {
      "type": "string"
    },
    "signoff_id": {
      "type": "string"
    },
    "promotion_packet_candidate_id": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "publication_blocked_human_review_required",
        "private_package_blockers_partially_resolved",
        "private_package_blockers_resolved_publication_still_blocked"
      ]
    },
    "private_blocker_resolution_dossier_only": {
      "type": "boolean",
      "const": true
    },
    "not_publication_approval": {
      "type": "boolean",
      "const": true
    },
    "not_real_promotion_packet": {
      "type": "boolean",
      "const": true
    },
    "not_public_preview": {
      "type": "boolean",
      "const": true
    },
    "not_public_record_creation": {
      "type": "boolean",
      "const": true
    },
    "public_publish_allowed": {
      "type": "boolean",
      "const": false
    },
    "real_promotion_packet_allowed": {
      "type": "boolean",
      "const": false
    },
    "public_preview_allowed": {
      "type": "boolean",
      "const": false
    },
    "public_record_creation_allowed": {
      "type": "boolean",
      "const": false
    },
    "remote_write_allowed": {
      "type": "boolean",
      "const": false
    },
    "raw_text_storage_allowed": {
      "type": "boolean",
      "const": false
    },
    "html_storage_allowed": {
      "type": "boolean",
      "const": false
    },
    "blocker_ledger": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "blocker_id",
          "source_signoff_blocker_id",
          "source_dimension",
          "blocker_type",
          "original_status",
          "t070_status",
          "resolution_basis",
          "evidence_references",
          "remaining_action",
          "human_review_required"
        ],
        "properties": {
          "blocker_id": {
            "type": "string"
          },
          "source_signoff_blocker_id": {
            "type": "string"
          },
          "source_dimension": {
            "type": "string"
          },
          "blocker_type": {
            "type": "string",
            "enum": [
              "technical_private_package",
              "human_legal_publication"
            ]
          },
          "original_status": {
            "type": "string"
          },
          "t070_status": {
            "type": "string",
            "enum": [
              "resolved",
              "requires_human_publication_review",
              "publication_blocked"
            ]
          },
          "resolution_basis": {
            "type": "string"
          },
          "evidence_references": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "remaining_action": {
            "type": "string"
          },
          "human_review_required": {
            "type": "boolean"
          }
        },
        "additionalProperties": false
      }
    },
    "safety_flags": {
      "type": "object",
      "required": [
        "no_raw_html",
        "no_long_third_party_text",
        "no_secrets",
        "no_inc_0014_created",
        "no_real_promotion_packet",
        "no_public_preview",
        "no_public_site_mutation",
        "no_publication_approval_granted"
      ],
      "properties": {
        "no_raw_html": { "type": "boolean", "const": true },
        "no_long_third_party_text": { "type": "boolean", "const": true },
        "no_secrets": { "type": "boolean", "const": true },
        "no_inc_0014_created": { "type": "boolean", "const": true },
        "no_real_promotion_packet": { "type": "boolean", "const": true },
        "no_public_preview": { "type": "boolean", "const": true },
        "no_public_site_mutation": { "type": "boolean", "const": true },
        "no_publication_approval_granted": { "type": "boolean", "const": true }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
