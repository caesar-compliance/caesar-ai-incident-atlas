{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://caesar.no/schemas/pipeline/private-promotion-packet-candidate.schema.json",
  "title": "Private Promotion Packet Candidate Package Schema",
  "description": "Schema for private promotion packet candidate preparation. This is NOT publication approval. No public record is created, and all publication/permission flags must be strictly false.",
  "type": "object",
  "required": [
    "candidate_packet_id",
    "created_at",
    "source_run_id",
    "dry_run_id",
    "package_id",
    "signoff_id",
    "status",
    "note",
    "public_publish_allowed",
    "real_promotion_packet_allowed",
    "public_preview_allowed",
    "public_record_creation_allowed",
    "remote_write_allowed",
    "raw_text_storage_allowed",
    "html_storage_allowed",
    "safety_flags",
    "private_package_preparation_checklist",
    "publication_approval_state"
  ],
  "properties": {
    "candidate_packet_id": {
      "type": "string",
      "pattern": "^PROMO-PACKET-CAND-[A-Z0-9-]+-[0-9]{3}$",
      "description": "Deterministic candidate package ID."
    },
    "created_at": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(\\.[0-9]+)?Z$",
      "description": "ISO 8601 UTC timestamp of creation."
    },
    "source_run_id": {
      "type": "string",
      "description": "Linked regulatory source green run ID."
    },
    "dry_run_id": {
      "type": "string",
      "description": "Linked T067 dry-run ID."
    },
    "package_id": {
      "type": "string",
      "description": "Linked T066 private draft package ID."
    },
    "signoff_id": {
      "type": "string",
      "description": "Linked T068 private signoff ID."
    },
    "status": {
      "type": "string",
      "const": "private_promotion_packet_candidate_prepared",
      "description": "The current status of candidate package preparation."
    },
    "note": {
      "type": "string",
      "description": "Clear note emphasizing private only, not real promotion packet."
    },
    "public_publish_allowed": {
      "type": "boolean",
      "const": false,
      "description": "Must be strictly false."
    },
    "real_promotion_packet_allowed": {
      "type": "boolean",
      "const": false,
      "description": "Must be strictly false."
    },
    "public_preview_allowed": {
      "type": "boolean",
      "const": false,
      "description": "Must be strictly false."
    },
    "public_record_creation_allowed": {
      "type": "boolean",
      "const": false,
      "description": "Must be strictly false."
    },
    "remote_write_allowed": {
      "type": "boolean",
      "const": false,
      "description": "Must be strictly false."
    },
    "raw_text_storage_allowed": {
      "type": "boolean",
      "const": false,
      "description": "Must be strictly false."
    },
    "html_storage_allowed": {
      "type": "boolean",
      "const": false,
      "description": "Must be strictly false."
    },
    "safety_flags": {
      "type": "object",
      "required": [
        "no_raw_html",
        "no_long_third_party_text",
        "no_secrets",
        "no_inc_0014_created",
        "no_real_promotion_packet",
        "no_public_preview",
        "no_public_site_mutation"
      ],
      "properties": {
        "no_raw_html": { "type": "boolean", "const": true },
        "no_long_third_party_text": { "type": "boolean", "const": true },
        "no_secrets": { "type": "boolean", "const": true },
        "no_inc_0014_created": { "type": "boolean", "const": true },
        "no_real_promotion_packet": { "type": "boolean", "const": true },
        "no_public_preview": { "type": "boolean", "const": true },
        "no_public_site_mutation": { "type": "boolean", "const": true }
      },
      "additionalProperties": false
    },
    "private_package_preparation_checklist": {
      "type": "object",
      "required": [
        "source_chain_referenced",
        "parent_package_referenced",
        "dry_run_referenced",
        "signoff_referenced",
        "blockers_preserved",
        "safety_flags_locked",
        "console_export_ready",
        "hosted_payload_sanitized"
      ],
      "properties": {
        "source_chain_referenced": { "type": "boolean", "const": true },
        "parent_package_referenced": { "type": "boolean", "const": true },
        "dry_run_referenced": { "type": "boolean", "const": true },
        "signoff_referenced": { "type": "boolean", "const": true },
        "blockers_preserved": { "type": "boolean", "const": true },
        "safety_flags_locked": { "type": "boolean", "const": true },
        "console_export_ready": { "type": "boolean", "const": true },
        "hosted_payload_sanitized": { "type": "boolean", "const": true }
      },
      "additionalProperties": false
    },
    "publication_approval_state": {
      "type": "object",
      "required": [
        "status",
        "unresolved_blocker_count",
        "publication_blockers"
      ],
      "properties": {
        "status": { "type": "string", "enum": ["blocked", "pending"] },
        "unresolved_blocker_count": { "type": "integer", "minimum": 1 },
        "publication_blockers": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
