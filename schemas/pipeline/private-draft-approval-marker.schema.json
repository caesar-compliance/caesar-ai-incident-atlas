{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://caesar.no/schemas/pipeline/private-draft-approval-marker.schema.json",
  "title": "Caesar AI Legal & Governance Case Atlas — Private Draft Approval Marker Schema",
  "type": "object",
  "required": [
    "approval_id",
    "created_at",
    "approval_scope",
    "source_run_id",
    "intake_id",
    "decision_id",
    "approved_decision_status",
    "approval_status",
    "control_tower_approval_required",
    "control_tower_approval_present",
    "approval_reason",
    "approval_notes",
    "requested_by",
    "approved_by",
    "expires_at",
    "public_publish_allowed",
    "promotion_packet_allowed",
    "public_preview_allowed",
    "remote_write_allowed",
    "raw_text_storage_allowed",
    "html_storage_allowed",
    "safety_flags"
  ],
  "properties": {
    "approval_id": {
      "type": "string",
      "pattern": "^APPROVAL-[A-Z0-9-]+-[0-9]{3}$",
      "description": "Unique, deterministic approval ID."
    },
    "created_at": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(\\.[0-9]+)?Z$",
      "description": "ISO 8601 UTC timestamp of creation."
    },
    "approval_scope": {
      "type": "string",
      "const": "private_draft_candidate_only",
      "description": "Must be private_draft_candidate_only."
    },
    "source_run_id": {
      "type": "string",
      "description": "The green source run ID linked to this ingestion cycle."
    },
    "intake_id": {
      "type": "string",
      "pattern": "^INTAKE-[A-Z0-9-]+-[0-9]{3}$",
      "description": "Linked intake record ID."
    },
    "decision_id": {
      "type": "string",
      "pattern": "^DECISION-[A-Z0-9-]+-[0-9]{3}$",
      "description": "Linked decision record ID."
    },
    "approved_decision_status": {
      "type": "string",
      "const": "approve_for_private_draft",
      "description": "Must be approve_for_private_draft."
    },
    "approval_status": {
      "type": "string",
      "enum": ["draft", "approved_for_private_draft", "revoked", "expired"],
      "description": "Active status of approval marker."
    },
    "control_tower_approval_required": {
      "type": "boolean",
      "const": true,
      "description": "Must be true."
    },
    "control_tower_approval_present": {
      "type": "boolean",
      "description": "Indicates if the Control Tower signature is present."
    },
    "approval_reason": {
      "type": "string",
      "description": "Reason for approving the private draft promotion."
    },
    "approval_notes": {
      "type": "string",
      "description": "Any additional review audit trail logs."
    },
    "requested_by": {
      "type": "string",
      "description": "Who requested the approval."
    },
    "approved_by": {
      "type": "string",
      "description": "Who approved it (must be empty/blank in template)."
    },
    "expires_at": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(\\.[0-9]+)?Z$",
      "description": "ISO 8601 UTC timestamp of expiration."
    },
    "public_publish_allowed": {
      "type": "boolean",
      "const": false,
      "description": "Must be false."
    },
    "promotion_packet_allowed": {
      "type": "boolean",
      "const": false,
      "description": "Must be false."
    },
    "public_preview_allowed": {
      "type": "boolean",
      "const": false,
      "description": "Must be false."
    },
    "remote_write_allowed": {
      "type": "boolean",
      "const": false,
      "description": "Must be false."
    },
    "raw_text_storage_allowed": {
      "type": "boolean",
      "const": false,
      "description": "Must be false."
    },
    "html_storage_allowed": {
      "type": "boolean",
      "const": false,
      "description": "Must be false."
    },
    "safety_flags": {
      "type": "object",
      "required": [
        "no_raw_html",
        "no_long_third_party_text",
        "no_secrets_exposed",
        "no_unauthorized_remote_writes",
        "no_public_site_leak"
      ],
      "properties": {
        "no_raw_html": { "type": "boolean", "const": true },
        "no_long_third_party_text": { "type": "boolean", "const": true },
        "no_secrets_exposed": { "type": "boolean", "const": true },
        "no_unauthorized_remote_writes": { "type": "boolean", "const": true },
        "no_public_site_leak": { "type": "boolean", "const": true }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
